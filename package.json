{
  "name": "eslint-suggestion-action",
  "version": "4.1.27",
  "description": "This GitHub Action runs ESLint and provides inline feedback to the changes in a Pull Request.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CatChen/eslint-suggestion-action.git"
  },
  "author": "Cat Chen",
  "homepage": "https://github.com/CatChen/eslint-suggestion-action#readme",
  "bugs": {
    "url": "https://github.com/CatChen/eslint-suggestion-action/issues"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "bundle": "rm -rf bundle && ncc build src/index.ts --source-map --license licenses.txt --out bundle",
    "codegen": "rm -rf src/__graphql__ && graphql-codegen-esm --config codegen.ts",
    "format": "prettier --write .",
    "lint": "eslint -c eslint.config.js",
    "postpublish": "pinst --enable",
    "prepare": "is-ci || husky",
    "prepublishOnly": "pinst --disable && yarn build",
    "preversion": "yarn && yarn build && yarn bundle",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@octokit/core": "^7.0.0",
    "@octokit/plugin-retry": "^8.0.1",
    "@octokit/plugin-throttling": "^11.0.1",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-document-nodes": "^5.0.7",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/eslint": "^9.6.0",
    "@types/glob": "^9.0.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "@vercel/ncc": "0.38.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.0.0",
    "graphql": "^16.12.0",
    "husky": "^9.0.5",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.0.0",
    "pinst": "^3.0.0",
    "prettier": "^3.0.2",
    "prettier-plugin-package": "^2.0.0",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.0.1"
  },
  "resolutions": {
    "strip-ansi": "6.0.1"
  },
  "types": "dist/index.d.js",
  "funding": "https://github.com/CatChen/eslint-suggestion-action?sponsor=1",
  "lint-staged": {
    "*.{ts,js}": [
      "yarn format",
      "yarn lint --fix"
    ],
    "*.{json,yml,yaml,md,markdown}": "yarn format"
  },
  "packageManager": "yarn@4.13.0"
}
